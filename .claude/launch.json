{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "fisiologia-streamlit",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": [
        "-m",
        "streamlit",
        "run",
        "app.py",
        "--server.headless",
        "true",
        "--server.port",
        "8599",
        "--browser.gatherUsageStats",
        "false"
      ],
      "port": 8599
    }
  ]
}
